                    </children>
                </HBox>

                <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;">
                    <content>
                        <FlowPane fx:id="productContainer" hgap="20.0" prefHeight="510.0" prefWidth="658.0" prefWrapLength="650.0" vgap="20.0">
